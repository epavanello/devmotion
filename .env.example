PUBLIC_BASE_URL=http://localhost:5173
PRIVATE_DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"
PRIVATE_BETTER_AUTH_SECRET=mysecretpassword

# Google OAuth
PRIVATE_GOOGLE_CLIENT_ID=your_google_client_id_here
PRIVATE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI Generation (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (Whisper transcription for captions)
OPENAI_API_KEY=your_openai_api_key_here

# Lummi Stock Images API
LUMMI_API_KEY=your_lummi_api_key_here

# S3-compatible Storage (AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, etc.)
PRIVATE_S3_BUCKET=devmotion-uploads
PRIVATE_S3_REGION=us-east-1
# Leave empty for AWS S3, set for R2/MinIO/etc.
PRIVATE_S3_ENDPOINT=
PRIVATE_S3_ACCESS_KEY_ID=your_access_key
PRIVATE_S3_SECRET_ACCESS_KEY=your_secret_key
# Optional: custom public URL for assets
PRIVATE_S3_PUBLIC_URL=

# Resend API (for transactional emails)
RESEND_API_KEY=your_resend_api_key_here
# Polar Payment Integration
# Get your Organization Access Token from https://polar.sh/settings/tokens
# Use 'production' for live payments, 'sandbox' for testing
POLAR_ACCESS_TOKEN=your_polar_access_token_here
POLAR_SERVER=sandbox
# Webhook secret for verifying Polar webhook signatures
# Get this from https://polar.sh/settings/webhooks
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret_here
# Product IDs from Polar dashboard (create products first)
PUBLIC_POLAR_CREATOR_PRODUCT_ID=your_creator_product_id_here
PUBLIC_POLAR_PRO_PRODUCT_ID=your_pro_product_id_here

